# ── Google Gemini (Study Space, Scanner) ──────────────────────────────────────
# Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# ── OpenRouter (Chat, Prompt Builder) ─────────────────────────────────────────
# Lấy tại https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── Database Configuration ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_feedback

# ── JWT Configuration ──────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Service Configuration ──────────────────────────────────────────────────
AI_MODEL_NAME=gemini-pro

# ── Server config ──────────────────────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:3000
SITE_URL=https://ai-gia-su.vercel.app
DEBUG=True
LOG_LEVEL=INFO
HOST=0.0.0.0
