# Server
PORT=5000
NODE_ENV=production

# Gemini API — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — production origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,https://multi-ai-agent-studies.vercel.app

# Vercel project name — cho phép tất cả preview URLs của project này
# Ví dụ: nếu preview URL là multi-ai-agent-studies-abc123.vercel.app
# thì điền: multi-ai-agent-studies
VERCEL_PROJECT_NAME=multi-ai-agent-studies
