# ── Supabase (Prompt Library) ─────────────────────────────────────────────────
# Lấy tại Supabase Dashboard → Settings → API
# Đây là public keys — được thiết kế để dùng trên trình duyệt (bảo vệ bằng RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Backend URL ───────────────────────────────────────────────────────────────
# URL của Express backend (backend/.env → PORT=4000)
# Dev: http://localhost:4000  |  Prod: URL deploy trên Railway/Render
NEXT_PUBLIC_API_URL=http://localhost:4000
