# ── Gemini API (Study Space, Scanner, Prompt Builder) ────────────────────────
# Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenRouter API (Chat — Claude 3 Haiku / Claude 3.5 Sonnet) ───────────────
# Lấy tại https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── Supabase (Prompt Library) ─────────────────────────────────────────────────
# Lấy tại Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Server config ─────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
SITE_URL=https://ai-gia-su.vercel.app
