# ── Gemini API (Prompt Builder, Scanner, Study Space) ────────────────────────
# Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenRouter API (Chat — Claude 3 Haiku / Claude 3.5 Sonnet) ───────────────
# Lấy tại https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ── Supabase (Prompt Library) ─────────────────────────────────────────────────
# Lấy tại Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Backend URL (tuỳ chọn) ────────────────────────────────────────────────────
# Để trống = dùng Next.js API routes mặc định
# Điền nếu muốn trỏ tới Express backend riêng (Railway)
NEXT_PUBLIC_API_URL=
